<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
	<name>MOD_DC_GSLIDER</name>
	<creationDate>2026-01</creationDate>
	<author>Design Cart</author>
	<copyright>Copyright (C) 2025. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<version>1.0.0</version>
	<description>MOD_DC_GSLIDER_XML_DESCRIPTION</description>
	<files>
		<filename module="mod_dc_gslider">mod_dc_gslider.php</filename>
		<folder>tmpl</folder>
		<folder>language</folder>
	</files>
	<media destination="mod_dc_gslider" folder="media">
		<filename>css/style.css</filename>
		<filename>js/slider.js</filename>
	</media>
	<languages>
		<language tag="en-GB">language/en-GB/en-GB.mod_dc_gslider.ini</language>
		<language tag="en-GB">language/en-GB/en-GB.mod_dc_gslider.sys.ini</language>
		<language tag="pl-PL">language/pl-PL/pl-PL.mod_dc_gslider.ini</language>
		<language tag="pl-PL">language/pl-PL/pl-PL.mod_dc_gslider.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="slides" label="MOD_DC_GSLIDER_TAB_SLIDES">
				<field
					name="slides"
					type="subform"
					label="MOD_DC_GSLIDER_FIELD_SLIDES_LABEL"
					multiple="true"
					layout="joomla.form.field.subform.repeatable-table"
					buttons="add,remove"
					>
					<form>
						<field name="heading" type="text" label="MOD_DC_GSLIDER_FIELD_HEADING_LABEL" filter="string" />
						<field name="description" type="textarea" label="MOD_DC_GSLIDER_FIELD_DESCRIPTION_LABEL" filter="safehtml" rows="3" />
						<field name="button_text" type="text" label="MOD_DC_GSLIDER_FIELD_BUTTON_TEXT_LABEL" filter="string" />
						<field name="button_link" type="url" label="MOD_DC_GSLIDER_FIELD_BUTTON_LINK_LABEL" filter="url" />
						<field name="image" type="media" label="MOD_DC_GSLIDER_FIELD_IMAGE_LABEL" />
					</form>
				</field>
			</fieldset>

			<fieldset name="appearance" label="MOD_DC_GSLIDER_TAB_APPEARANCE">
				<field name="module_bg" type="color" label="MOD_DC_GSLIDER_FIELD_MODULE_BG_LABEL" default="#1a1a1a" />
				<field name="slider_height" type="text" label="MOD_DC_GSLIDER_FIELD_SLIDER_HEIGHT_LABEL" description="MOD_DC_GSLIDER_FIELD_SLIDER_HEIGHT_DESC" default="420" filter="string" size="10" />
				<field name="heading_tag" type="list" label="MOD_DC_GSLIDER_FIELD_HEADING_TAG_LABEL" default="h1" validate="options">
					<option value="h1">MOD_DC_GSLIDER_HEADING_H1</option>
					<option value="h2">MOD_DC_GSLIDER_HEADING_H2</option>
					<option value="p">MOD_DC_GSLIDER_HEADING_P</option>
				</field>
				<field name="heading_font_size" type="number" label="MOD_DC_GSLIDER_FIELD_HEADING_FONT_SIZE_LABEL" default="48" filter="integer" min="12" max="120" />
				<field name="heading_color" type="color" label="MOD_DC_GSLIDER_FIELD_HEADING_COLOR_LABEL" default="#ffffff" />
				<field name="description_font_size" type="number" label="MOD_DC_GSLIDER_FIELD_DESCRIPTION_FONT_SIZE_LABEL" default="18" filter="integer" min="12" max="48" />
				<field name="description_color" type="color" label="MOD_DC_GSLIDER_FIELD_DESCRIPTION_COLOR_LABEL" default="#ffffff" />
				<field name="content_position" type="list" label="MOD_DC_GSLIDER_FIELD_CONTENT_POSITION_LABEL" default="left" validate="options">
					<option value="left">MOD_DC_GSLIDER_POSITION_LEFT</option>
					<option value="center">MOD_DC_GSLIDER_POSITION_CENTER</option>
					<option value="right">MOD_DC_GSLIDER_POSITION_RIGHT</option>
				</field>
				<field name="button_bg" type="color" label="MOD_DC_GSLIDER_FIELD_BUTTON_BG_LABEL" default="#27C07C" />
				<field name="button_bg_hover" type="color" label="MOD_DC_GSLIDER_FIELD_BUTTON_BG_HOVER_LABEL" default="#22a86a" />
				<field name="button_color" type="color" label="MOD_DC_GSLIDER_FIELD_BUTTON_COLOR_LABEL" default="#ffffff" />
				<field name="button_color_hover" type="color" label="MOD_DC_GSLIDER_FIELD_BUTTON_COLOR_HOVER_LABEL" default="#ffffff" />
				<field name="button_font_size" type="number" label="MOD_DC_GSLIDER_FIELD_BUTTON_FONT_SIZE_LABEL" default="16" filter="integer" min="12" max="24" />
				<field name="arc_border_color" type="color" label="MOD_DC_GSLIDER_FIELD_ARC_BORDER_COLOR_LABEL" default="#27C07C" />
				<field name="arc_border_width" type="number" label="MOD_DC_GSLIDER_FIELD_ARC_BORDER_WIDTH_LABEL" default="3" filter="integer" min="0" max="20" />
			</fieldset>

			<fieldset name="gradient" label="MOD_DC_GSLIDER_TAB_GRADIENT">
				<field
					name="gradient_enable"
					type="radio"
					label="MOD_DC_GSLIDER_FIELD_GRADIENT_ENABLE_LABEL"
					layout="joomla.form.field.radio.switcher"
					default="0"
					filter="integer"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field
					name="gradient_colors"
					type="subform"
					label="MOD_DC_GSLIDER_FIELD_GRADIENT_COLORS_LABEL"
					multiple="true"
					layout="joomla.form.field.subform.repeatable-table"
					buttons="add,remove"
					showon="gradient_enable:1"
					>
					<form>
						<field name="color1" type="color" label="MOD_DC_GSLIDER_FIELD_GRADIENT_COLOR1_LABEL" default="#29323c" />
						<field name="color2" type="color" label="MOD_DC_GSLIDER_FIELD_GRADIENT_COLOR2_LABEL" default="#485563" />
					</form>
				</field>
			</fieldset>

			<fieldset name="jquery" label="MOD_DC_GSLIDER_TAB_JQUERY">
				<field
					name="load_jquery"
					type="radio"
					label="MOD_DC_GSLIDER_FIELD_LOAD_JQUERY_LABEL"
					layout="joomla.form.field.radio.switcher"
					default="0"
					filter="integer"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
			</fieldset>

			<fieldset name="advanced">
				<field name="layout" type="modulelayout" label="JFIELD_ALT_LAYOUT_LABEL" class="form-select" validate="moduleLayout" />
				<field name="moduleclass_sfx" type="textarea" label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL" rows="3" validate="CssIdentifier" />
				<field name="cache" type="list" label="COM_MODULES_FIELD_CACHING_LABEL" default="1" filter="integer" validate="options">
					<option value="1">JGLOBAL_USE_GLOBAL</option>
					<option value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
				</field>
				<field name="cache_time" type="number" label="COM_MODULES_FIELD_CACHE_TIME_LABEL" default="900" filter="integer" />
			</fieldset>
		</fields>
	</config>
</extension>
